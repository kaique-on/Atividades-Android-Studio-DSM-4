<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_geometria_areas"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <RadioGroup
            android:id="@+id/radioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbCirculo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rb_circulo" />

            <RadioButton
                android:id="@+id/rbRetangulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rb_retangulo" />

            <RadioButton
                android:id="@+id/rbTriangulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rb_triangulo" />

        </RadioGroup>

        <LinearLayout
            android:id="@+id/layoutCirculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/edtRaio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_raio"
                android:inputType="numberDecimal"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutRetangulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/edtBaseRect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_base"
                android:inputType="numberDecimal"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edtAlturaRect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_altura"
                android:inputType="numberDecimal"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutTriangulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/edtBaseTri"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_base"
                android:inputType="numberDecimal"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edtAlturaTri"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_altura"
                android:inputType="numberDecimal"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnCalcular"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_calcular"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:padding="8dp" />

    </LinearLayout>
</ScrollView>
