<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/titulo_energia_mecanica"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/edtMassa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_massa"
        android:inputType="numberDecimal"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/edtAltura"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_altura"
        android:inputType="numberDecimal"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/edtVelocidade"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_velocidade"
        android:inputType="numberDecimal"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_calcular"
        android:layout_marginBottom="8dp" />

    <CheckBox
        android:id="@+id/cbEnergiaPotencial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cb_energia_potencial" />

    <CheckBox
        android:id="@+id/cbEnergiaKinetica"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cb_energia_cinetica" />

    <CheckBox
        android:id="@+id/cbEnergiaMecanica"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/cb_energia_mecanica" />

    <Button
        android:id="@+id/btnCalcular"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_calcular"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvResultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:padding="8dp" />

</LinearLayout>
